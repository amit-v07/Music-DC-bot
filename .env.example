# ──────────────────────────────────────────────────────────────────────────────
# Music Bot — Environment Variables Template
# Copy to .env and fill in your credentials.  NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
DEFAULT_PREFIX=!          # Default command prefix (can be changed per-server with !setprefix)
DEFAULT_VOLUME=0.5        # Volume range: 0.1 – 2.0
IDLE_TIMEOUT=300          # Seconds before the bot leaves an idle voice channel
ALONE_TIMEOUT=60          # Seconds before the bot leaves when alone in VC
# Autoplay: how many related tracks to add per wave (queue end / buffer). Raise (e.g. 5) for more variety per wave.
AUTOPLAY_SONGS_PER_BATCH=2
# Max simultaneous voice streams across all guilds (FFmpeg / Discord voice cap).
MAX_CONCURRENT_STREAMS=4

# ── Spotify Integration (Optional) ───────────────────────────────────────────
# Get from https://developer.spotify.com/dashboard/
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# ── Gemini AI (Optional) ──────────────────────────────────────────────────────
# Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Dashboard Security ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# DASHBOARD_SECRET_KEY is preferred; FLASK_SECRET_KEY still works if unset.
DASHBOARD_SECRET_KEY=
FLASK_SECRET_KEY=your_random_secret_key_here

# PIN required to use the dashboard's remote control panel (min 6 chars)
ADMIN_PIN=your_secure_pin_here

# ── Discord Webhook (Optional) ────────────────────────────────────────────────
# Used for error/alert notifications to a Discord channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container — must match the volume mount in docker-compose.yml
# Default is /data/music_bot.db (the bot-data named volume).  Do not change
# unless you also update docker-compose.yml.
DB_PATH=/data/music_bot.db
